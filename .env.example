# ─── Database ────────────────────────────────────────────────────────────────
# Used by the app at runtime and by drizzle-kit for migrations.
# For Docker Compose the host is the service name "db".
DATABASE_URL=mysql://app:apppassword@db:3306/driveway

# ─── MySQL (Docker Compose only) ─────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=driveway
MYSQL_USER=app
MYSQL_PASSWORD=apppassword

# ─── Auth / Sessions ─────────────────────────────────────────────────────────
# Random secret used to sign JWT session cookies.  Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_32_byte_hex_string

# ─── App Identity ────────────────────────────────────────────────────────────
# Public app identifier used inside signed session tokens.
VITE_APP_ID=your_manus_app_id

# ─── Forge / Storage (S3 presign proxy) ──────────────────────────────────────
# Used to upload photos and generate material previews via the Manus Forge API.
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your_forge_api_key

# ─── Owner bootstrap ─────────────────────────────────────────────────────────
# Optional: this email is granted admin access when the account is created.
OWNER_EMAIL=owner@example.com

# ─── App (optional) ──────────────────────────────────────────────────────────
PORT=3000
HOST=127.0.0.1
APP_PORT=3000          # host port mapped in docker-compose

# Public HTTPS origin for native mobile builds. Required when building an APK
# with bundled web assets, because the app cannot call same-origin /api routes
# from the Capacitor localhost origin.
VITE_API_BASE_URL=https://your-production-app.example.com

# Comma-separated extra origins allowed to call the API with credentials.
# Keep this tight; do not use wildcards.
MOBILE_ALLOWED_ORIGINS=https://your-production-app.example.com
