# ─── Database ────────────────────────────────────────────────────────────────
# Used by the app at runtime and by drizzle-kit for migrations.
# For Docker Compose the host is the service name "db".
DATABASE_URL=mysql://app:apppassword@db:3306/driveway

# ─── MySQL (Docker Compose only) ─────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=driveway
MYSQL_USER=app
MYSQL_PASSWORD=apppassword

# ─── Auth / Sessions ─────────────────────────────────────────────────────────
# Random secret used to sign JWT session cookies.  Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_32_byte_hex_string

# ─── OAuth (Manus) ───────────────────────────────────────────────────────────
# Your Manus app ID and OAuth endpoints.
VITE_APP_ID=your_manus_app_id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://oauth.manus.im

# ─── Forge / Storage (S3 presign proxy) ──────────────────────────────────────
# Used to upload photos and generate material previews via the Manus Forge API.
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your_forge_api_key

# ─── Owner bootstrap ─────────────────────────────────────────────────────────
# The Manus openId of the first admin user (seeded automatically on first login).
OWNER_OPEN_ID=your_manus_open_id
OWNER_NAME=Your Name

# ─── App (optional) ──────────────────────────────────────────────────────────
PORT=3000
APP_PORT=3000          # host port mapped in docker-compose
