{
  "name": "driveway-estimator-pro",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch server/_core/index.ts",
    "dev:web": "pnpm --filter @easy-asphalt/client dev",
    "dev:server": "pnpm --filter @easy-asphalt/server dev",
    "build": "vite build && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist && cp dist/public/index.html dist/index.html",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "check:workspaces": "pnpm -r check",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "mobile:build": "pnpm build && pnpm exec cap sync",
    "mobile:ios": "pnpm mobile:build && pnpm exec cap open ios",
    "mobile:android": "pnpm mobile:build && pnpm exec cap open android",
    "mobile:build-ios": "cd ios/App && xcodebuild -workspace App.xcworkspace -scheme App -configuration Release",
    "mobile:build-android": "cd android && ./gradlew assembleRelease",
    "mobile:build-android-debug": "cd android && ./gradlew assembleDebug",
    "mobile:apk": "pnpm mobile:build && pnpm mobile:build-android-debug"
  },
